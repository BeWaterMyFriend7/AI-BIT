{
  "manifest_version": 3,
  "name": "链接收藏管理器",
  "version": "1.0.0",
  "description": "内网环境下的一键保存和导入浏览器标签页链接工具",
  "permissions": [
    "tabs",
    "downloads",
    "storage",
    "bookmarks"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "链接收藏管理器"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
